{
  "version": 2,

  "framework": null,

  "buildCommand": "bash vercel-build.sh",

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },

  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}